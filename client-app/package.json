    "highlight.js": "^11.11.1",
    "lodash": "^4.17.21",
    "markdown-it": "^14.1.0",
    "mermaid": "^10.9.5",
    "pinia": "^2.3.1",
    "uuid": "^14.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "vuetify": "^3.8.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
