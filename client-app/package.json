{
  "name": "client-app",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:Debug": "vite build --mode Debug",
    "build:QAS": "vite build --mode QAS",
    "build:Release": "vite build --mode Release",
    "build:QAS_Release": "concurrently \"npm run build:QAS\" \"npm run build:Release\"",
